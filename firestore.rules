rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDocKeysAreSafe() {
      return request.resource.data.keys().hasOnly([
        "studentId",
        "displayName",
        "classId",
        "lastLoginAt",
        "bestStreak",
        "vocabCacheOwner",
        "updatedAt"
      ]);
    }

    function studentIdMatchesToken() {
      return !("studentId" in request.resource.data)
        || !("studentId" in request.auth.token)
        || request.resource.data.studentId == request.auth.token.studentId;
    }

    function classIdMatchesToken() {
      return !("classId" in request.resource.data)
        || !("classId" in request.auth.token)
        || request.resource.data.classId == request.auth.token.classId;
    }

    function grammarProgressKeysAreSafe() {
      return request.resource.data.keys().hasOnly([
        "lessonId",
        "completed",
        "total",
        "updatedAt",
        "syncedAt"
      ]);
    }

    function vocabProgressKeysAreSafe(progress) {
      return progress.keys().hasOnly([
        "lastSeenAt",
        "totalSeen",
        "totalCorrect",
        "totalIncorrect",
        "streakCorrect",
        "mastery",
        "nextDueAt",
        "lastRecallProb",
        "halfLifeDays",
        "updatedAt"
      ]);
    }

    function vocabItemKeysAreSafe() {
      return request.resource.data.keys().hasOnly([
        "word",
        "meaning",
        "createdAt",
        "updatedAt",
        "deletedAt",
        "progress",
        "ownerUid",
        "syncedAt"
      ]);
    }

    function vocabItemFieldsAreSafe() {
      return (!("ownerUid" in request.resource.data) || request.resource.data.ownerUid == request.auth.uid)
        && (!("word" in request.resource.data) || request.resource.data.word is string)
        && (!("meaning" in request.resource.data) || request.resource.data.meaning is string)
        && (!("createdAt" in request.resource.data) || request.resource.data.createdAt is number)
        && (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt is number)
        && (!("deletedAt" in request.resource.data) || request.resource.data.deletedAt is number)
        && (!("progress" in request.resource.data) || (request.resource.data.progress is map && vocabProgressKeysAreSafe(request.resource.data.progress)));
    }

    match /studentAccounts/{studentId} {
      allow read, write: if false;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && userDocKeysAreSafe()
        && studentIdMatchesToken()
        && classIdMatchesToken();
      allow delete: if false;

      match /grammarProgress/{lessonId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && grammarProgressKeysAreSafe()
          && request.resource.data.lessonId == lessonId;
        allow delete: if false;
      }

      match /vocabItems/{wordId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && vocabItemKeysAreSafe()
          && vocabItemFieldsAreSafe();
        allow delete: if false;
      }

      match /attempts/{attemptId} {
        allow read, create: if isOwner(uid);
        allow update, delete: if false;
      }

      match /achievements/{achievementId} {
        allow read, create, update: if isOwner(uid);
        allow delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
