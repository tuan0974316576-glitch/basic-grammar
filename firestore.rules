rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isTeacher() {
      return signedIn() && request.auth.token.role == "teacher";
    }

    function userDocKeysAreSafe() {
      return request.resource.data.keys().hasOnly([
        "studentId",
        "displayName",
        "classId",
        "role",
        "lastLoginAt",
        "bestStreak",
        "studyStreak",
        "vocabCacheOwner",
        "updatedAt"
      ]);
    }

    function studyStreakFieldsAreSafe(studyStreak) {
      return studyStreak.keys().hasOnly([
        "days",
        "lastDateKey",
        "lastCompletedDateKey",
        "updatedAt"
      ]);
    }

    function studentIdMatchesToken() {
      return isTeacher()
        || !("studentId" in request.resource.data)
        || !("studentId" in request.auth.token)
        || request.resource.data.studentId == request.auth.token.studentId;
    }

    function classIdMatchesToken() {
      return isTeacher()
        || !("classId" in request.resource.data)
        || !("classId" in request.auth.token)
        || request.resource.data.classId == request.auth.token.classId;
    }

    function grammarProgressKeysAreSafe() {
      return request.resource.data.keys().hasOnly([
        "lessonId",
        "completed",
        "total",
        "updatedAt",
        "syncedAt"
      ]);
    }

    function vocabProgressKeysAreSafe(progress) {
      return progress.keys().hasOnly([
        "lastSeenAt",
        "totalSeen",
        "totalCorrect",
        "totalIncorrect",
        "streakCorrect",
        "mastery",
        "nextDueAt",
        "lastRecallProb",
        "halfLifeDays",
        "updatedAt"
      ]);
    }

    function vocabItemKeysAreSafe() {
      return request.resource.data.keys().hasOnly([
        "word",
        "meaning",
        "meanings",
        "pos",
        "type",
        "source",
        "teacherEntryId",
        "sourceEntryId",
        "level",
        "createdAt",
        "updatedAt",
        "deletedAt",
        "progress",
        "ownerUid",
        "syncedAt"
      ]);
    }

    function vocabItemFieldsAreSafe() {
      return (!("ownerUid" in request.resource.data) || request.resource.data.ownerUid == request.auth.uid)
        && (!("word" in request.resource.data) || request.resource.data.word is string)
        && (!("meaning" in request.resource.data) || request.resource.data.meaning is string)
        && (!("meanings" in request.resource.data) || request.resource.data.meanings is list)
        && (!("pos" in request.resource.data) || request.resource.data.pos is string)
        && (!("type" in request.resource.data) || request.resource.data.type is string)
        && (!("source" in request.resource.data) || request.resource.data.source is string)
        && (!("teacherEntryId" in request.resource.data) || request.resource.data.teacherEntryId is string)
        && (!("sourceEntryId" in request.resource.data) || request.resource.data.sourceEntryId is string)
        && (!("level" in request.resource.data) || request.resource.data.level is string)
        && (!("createdAt" in request.resource.data) || request.resource.data.createdAt is number)
        && (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt is number)
        && (!("deletedAt" in request.resource.data) || request.resource.data.deletedAt is number)
        && (!("progress" in request.resource.data) || (request.resource.data.progress is map && vocabProgressKeysAreSafe(request.resource.data.progress)));
    }

    function teacherVocabKeysAreSafe() {
      return request.resource.data.keys().hasOnly([
        "word",
        "display",
        "meaning",
        "pos",
        "type",
        "aliases",
        "level",
        "source",
        "notes",
        "disabled",
        "replacedBy",
        "createdAt",
        "updatedAt",
        "createdBy",
        "updatedBy"
      ]);
    }

    function teacherVocabFieldsAreSafe() {
      return request.resource.data.word is string
        && request.resource.data.meaning is string
        && (!("display" in request.resource.data) || request.resource.data.display is string)
        && (!("pos" in request.resource.data) || request.resource.data.pos is string)
        && (!("type" in request.resource.data) || request.resource.data.type is string)
        && (!("aliases" in request.resource.data) || request.resource.data.aliases is list)
        && (!("level" in request.resource.data) || request.resource.data.level is string)
        && (!("source" in request.resource.data) || request.resource.data.source is string)
        && (!("notes" in request.resource.data) || request.resource.data.notes is string)
        && (!("disabled" in request.resource.data) || request.resource.data.disabled is bool)
        && (!("replacedBy" in request.resource.data) || request.resource.data.replacedBy is string)
        && (!("createdBy" in request.resource.data) || request.resource.data.createdBy is string)
        && (!("updatedBy" in request.resource.data) || request.resource.data.updatedBy == request.auth.uid);
    }

    match /studentAccounts/{studentId} {
      allow read, write: if false;
    }

    match /vocabMeaningCache/{meaningId} {
      allow read, write: if false;
    }

    match /teacherVocabLive/{entryId} {
      allow read: if signedIn();
      allow create, update: if isTeacher()
        && teacherVocabKeysAreSafe()
        && teacherVocabFieldsAreSafe();
      allow delete: if false;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && userDocKeysAreSafe()
        && (!("studyStreak" in request.resource.data) || (request.resource.data.studyStreak is map && studyStreakFieldsAreSafe(request.resource.data.studyStreak)))
        && studentIdMatchesToken()
        && classIdMatchesToken();
      allow delete: if false;

      match /grammarProgress/{lessonId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && grammarProgressKeysAreSafe()
          && request.resource.data.lessonId == lessonId;
        allow delete: if false;
      }

      match /vocabItems/{wordId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && vocabItemKeysAreSafe()
          && vocabItemFieldsAreSafe();
        allow delete: if false;
      }

      match /attempts/{attemptId} {
        allow read, create: if isOwner(uid);
        allow update, delete: if false;
      }

      match /achievements/{achievementId} {
        allow read, create, update: if isOwner(uid);
        allow delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
