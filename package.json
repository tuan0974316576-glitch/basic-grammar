{
  "name": "vocab-conqueror",
  "version": "1.0.0",
  "description": "Vocab Conqueror - Military-themed vocabulary learning game",
  "main": "index.html",
  "scripts": {
    "server": "node server/index.js",
    "warm:verb-audio": "node scripts/warm-verb-table-audio.js",
    "warm:listening-audio": "node scripts/warm-listening-audio.js",
    "warm:listening-audio-batch": "node scripts/warm-listening-audio-batch.js",
    "warm:vocab-audio": "node scripts/warm-vocab-word-audio.js",
    "native:web-assets": "node scripts/sync-capacitor-web.js",
    "native:audio-assets": "node scripts/sync-native-audio-assets.js",
    "native:prepare": "npm run native:web-assets && npm run native:audio-assets && npm run store:assets",
    "ios:patch-google-auth": "node scripts/patch-ios-google-auth-pod.js",
    "native:sync": "npm run native:prepare && npx cap sync && npm run ios:patch-google-auth",
    "store:assets": "swift scripts/generate-store-assets.swift",
    "store:screenshots": "node scripts/generate-store-screenshots.js",
    "build:ios": "npm run native:web-assets && npx cap add ios && npm run native:audio-assets && npx cap sync ios && npm run ios:patch-google-auth && npx cap open ios",
    "build:android": "npm run native:web-assets && npx cap add android && npm run native:audio-assets && npx cap sync android && npx cap open android",
    "android:play-upload": "bundle exec fastlane android play_upload",
    "android:play-upload-chunked": "node scripts/upload-play-aab.js",
    "android:play-build-upload": "bundle exec fastlane android play_build_and_upload",
    "sync": "npx cap sync && npm run ios:patch-google-auth"
  },
  "keywords": [
    "vocabulary",
    "education",
    "game"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@capacitor/cli": "^5.5.1",
    "playwright": "^1.60.0"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^5.0.0",
    "@capacitor-community/native-audio": "^5.0.1",
    "@capacitor/android": "^5.5.1",
    "@capacitor/core": "^5.5.1",
    "@capacitor/ios": "^5.5.1",
    "@capacitor/keyboard": "^5.0.7",
    "@capacitor/splash-screen": "^5.0.7",
    "@capacitor/status-bar": "^5.0.7",
    "@codetrix-studio/capacitor-google-auth": "^3.3.6",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "microsoft-cognitiveservices-speech-sdk": "^1.44.1",
    "multer": "^1.4.5-lts.2"
  }
}
