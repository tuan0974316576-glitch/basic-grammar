default_platform(:android)

require "fileutils"

opt_out_usage

platform :android do
  desc "Check that the Google Play service account JSON can access Play Console"
  lane :play_validate_key do
    json_key = ENV.fetch("SUPPLY_JSON_KEY", "fastlane/play-store-credentials.json")
    validate_play_store_json_key(json_key: json_key)
  end

  desc "Upload the current signed AAB to Google Play Console"
  lane :play_upload do |options|
    json_key = ENV.fetch("SUPPLY_JSON_KEY", "fastlane/play-store-credentials.json")
    aab_path = options[:aab] || ENV.fetch("PLAY_AAB", "build/android-play/EnglishConqueror-1.0.3-versionCode10.aab")
    track = options[:track] || ENV.fetch("PLAY_TRACK", "internal")
    release_status = options[:release_status] || ENV.fetch("PLAY_RELEASE_STATUS", "completed")

    upload_to_play_store(
      package_name: "com.enguistics.vocabconqueror",
      json_key: json_key,
      aab: aab_path,
      track: track,
      release_status: release_status,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end

  desc "Build a signed release AAB, copy it to build/android-play, then upload it"
  lane :play_build_and_upload do |options|
    sh("npm run native:sync")
    gradle(project_dir: "android", task: "bundle", build_type: "Release")
    aab_output = Actions.lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH] ||
      File.expand_path("../android/app/build/outputs/bundle/release/app-release.aab", __dir__)
    release_aab = File.expand_path("../build/android-play/EnglishConqueror-android-latest.aab", __dir__)
    FileUtils.mkdir_p(File.dirname(release_aab))
    FileUtils.cp(aab_output, release_aab)

    play_upload(
      aab: release_aab,
      track: options[:track],
      release_status: options[:release_status]
    )
  end

  desc "Upload store screenshots to Google Play Console"
  lane :play_upload_screenshots do |options|
    json_key = ENV.fetch("SUPPLY_JSON_KEY", "fastlane/play-store-credentials.json")
    gradle_path = File.expand_path("../android/app/build.gradle", __dir__)
    detected_version_code = File.read(gradle_path)[/versionCode\s+(\d+)/, 1]
    version_code = options[:version_code] || ENV.fetch("PLAY_VERSION_CODE", detected_version_code)
    track = options[:track] || ENV.fetch("PLAY_TRACK", "TESTING")

    upload_to_play_store(
      package_name: "com.enguistics.vocabconqueror",
      json_key: json_key,
      track: track,
      version_code: version_code.to_i,
      metadata_path: "fastlane/metadata/android",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: false,
      skip_upload_changelogs: true,
      sync_image_upload: true
    )
  end
end

platform :ios do
  desc "Build a release IPA and upload it to TestFlight"
  lane :testflight_build_upload do
    sh("npm run native:sync")
    sh("mkdir -p build/ios-testflight")

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      clean: true,
      output_directory: "build/ios-testflight",
      output_name: "EnglishConqueror.ipa",
      export_options: "ios/App/ExportOptions-AppStoreConnect.plist",
      xcargs: "-allowProvisioningUpdates"
    )

    upload_options = {
      app_identifier: "com.enguistics.vocabconqueror",
      ipa: "build/ios-testflight/EnglishConqueror.ipa",
      skip_waiting_for_build_processing: true
    }

    api_key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"] || ENV["PILOT_API_KEY_PATH"]
    if api_key_path && !api_key_path.empty?
      upload_options[:api_key_path] = api_key_path
    else
      default_key_filepath = File.expand_path("../AuthKey_2L5B4778XL.p8", __dir__)
      key_filepath = ENV.fetch("APP_STORE_CONNECT_API_KEY_FILE", default_key_filepath)
      if File.exist?(key_filepath)
        upload_options[:api_key] = app_store_connect_api_key(
          key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID", "2L5B4778XL"),
          issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID", "ca93dc9f-a644-40dc-bfa4-566d7392da39"),
          key_filepath: key_filepath,
          duration: 1200,
          in_house: false
        )
      end
    end

    username = ENV["PILOT_USERNAME"] || ENV["FASTLANE_USER"]
    upload_options[:username] = username if username && !username.empty?

    upload_to_testflight(upload_options)
  end

  desc "Upload store screenshots to App Store Connect"
  lane :appstore_upload_screenshots do
    project_path = File.expand_path("../ios/App/App.xcodeproj/project.pbxproj", __dir__)
    detected_app_version = File.read(project_path)[/MARKETING_VERSION\s*=\s*([^;]+);/, 1]

    deliver_options = {
      app_identifier: "com.enguistics.vocabconqueror",
      app_version: ENV.fetch("APP_STORE_VERSION", detected_app_version),
      screenshots_path: "fastlane/screenshots",
      skip_binary_upload: true,
      skip_metadata: ENV.fetch("APPSTORE_SKIP_METADATA", "false") == "true",
      skip_screenshots: ENV.fetch("APPSTORE_SKIP_SCREENSHOTS", "false") == "true",
      skip_app_version_update: false,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      submit_for_review: false,
      force: true
    }

    api_key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"] || ENV["DELIVER_API_KEY_PATH"]
    if api_key_path && !api_key_path.empty?
      deliver_options[:api_key_path] = api_key_path
    else
      default_key_filepath = File.expand_path("../AuthKey_2L5B4778XL.p8", __dir__)
      key_filepath = ENV.fetch("APP_STORE_CONNECT_API_KEY_FILE", default_key_filepath)
      if File.exist?(key_filepath)
        deliver_options[:api_key] = app_store_connect_api_key(
          key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID", "2L5B4778XL"),
          issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID", "ca93dc9f-a644-40dc-bfa4-566d7392da39"),
          key_filepath: key_filepath,
          duration: 1200,
          in_house: false
        )
      end
    end

    username = ENV["DELIVER_USERNAME"] || ENV["FASTLANE_USER"]
    deliver_options[:username] = username if username && !username.empty?

    upload_to_app_store(deliver_options)
  end
end
